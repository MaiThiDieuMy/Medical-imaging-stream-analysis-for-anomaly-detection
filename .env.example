# Demo-only local environment values. Do not use these values in production.

# Container images
POSTGRES_IMAGE=postgres:16-alpine
REDIS_IMAGE=redis:7-alpine
MINIO_IMAGE=quay.io/minio/minio:latest
MLFLOW_IMAGE=ghcr.io/mlflow/mlflow:latest
CADVISOR_IMAGE=gcr.io/cadvisor/cadvisor:latest
REDIS_EXPORTER_IMAGE=oliver006/redis_exporter:latest
POSTGRES_EXPORTER_IMAGE=prometheuscommunity/postgres-exporter:latest
LOKI_IMAGE=grafana/loki:latest
PROMTAIL_IMAGE=grafana/promtail:latest
REDISINSIGHT_IMAGE=redis/redisinsight:latest

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=xray_streaming
POSTGRES_USER=xray_demo
POSTGRES_PASSWORD=xray_demo_password
DATABASE_URL=postgresql+psycopg://xray_demo:xray_demo_password@postgres:5432/xray_streaming

# Redis / Celery
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_LOG_LEVEL=info

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minio_demo_user
MINIO_ROOT_PASSWORD=minio_demo_password
MINIO_ACCESS_KEY=minio_demo_user
MINIO_SECRET_KEY=minio_demo_password
MINIO_BUCKET=xray-images
MINIO_SECURE=false

# MLflow
MLFLOW_HOST=mlflow
MLFLOW_PORT=5000
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_UI_URL=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=chest-xray-stream-analysis
MLFLOW_REGISTERED_MODEL_NAME=chest-xray-mobilenetv3-small
MLFLOW_BACKEND_STORE_URI=sqlite:////mlflow/mlflow.db
MLFLOW_ARTIFACT_ROOT=/mlflow/artifacts
MLFLOW_ALLOWED_HOSTS=localhost,127.0.0.1,mlflow,mlflow:5000
MLFLOW_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5000,http://127.0.0.1:5000

# ML inference
# Docker Compose mounts ./artifacts/models to /app/artifacts/models.
MODEL_SOURCE=local
MODEL_ARCHITECTURE=mobilenet_v3_small
MODEL_WEIGHTS_PATH=/app/artifacts/models/best_model.pth
MODEL_DEVICE=cpu
MODEL_THRESHOLD=0.5
ALLOW_DEMO_MODEL=false

# Image storage
MAX_UPLOAD_SIZE_BYTES=10485760
ALLOWED_IMAGE_EXTENSIONS=.png,.jpg,.jpeg
ALLOWED_IMAGE_CONTENT_TYPES=image/png,image/jpeg,image/jpg

# Phase 5 MLOps review/retraining controls
LOW_CONFIDENCE_THRESHOLD=0.7
REVIEW_NEAR_THRESHOLD_MARGIN=0.1
RETRAIN_MIN_CONFIRMED_SAMPLES=15
AUTO_START_RETRAINING_JOB=false
RETRAIN_EPOCHS=3
RETRAIN_BATCH_SIZE=8
RETRAIN_LEARNING_RATE=0.0001
RETRAIN_VALIDATION_SPLIT=0.2
RETRAIN_REPLAY_METADATA_PATH=
RETRAIN_REPLAY_SAMPLES_PER_CLASS=30
RETRAIN_EVAL_MANIFEST_PATH=
RETRAIN_UNFREEZE_LAST_BLOCKS=0
AUTO_PROMOTE_RETRAINED_MODEL=false
PROMOTION_MAX_RECALL_DROP=0.02
RETRAIN_OUTPUT_DIR=/app/artifacts/models/retrained
RETRAIN_MANIFEST_DIR=/app/artifacts/retraining_manifests
RETRAINING_MANIFEST_DIR=/app/artifacts/retraining_manifests

# Prometheus / Grafana
PROMETHEUS_IMAGE=prom/prometheus:latest
PROMETHEUS_PORT=9090
GRAFANA_IMAGE=grafana/grafana:latest
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin123
CADVISOR_PORT=8080
REDIS_EXPORTER_PORT=9121
POSTGRES_EXPORTER_PORT=9187
LOKI_PORT=3100
FLOWER_PORT=5555
REDISINSIGHT_PORT=5540

# Future backend/frontend defaults
APP_NAME=Medical Imaging Stream Analysis API
APP_VERSION=0.1.0
APP_ENV=local
API_V1_PREFIX=/api/v1
FRONTEND_URL=http://localhost:5173
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_PORT=5173
VITE_API_BASE_URL=http://localhost:8000
